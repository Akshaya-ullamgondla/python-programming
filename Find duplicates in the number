class Solution:
    def findDuplicate(self, nums: List[int]) -> int:
        slow=nums[0]
        fast=nums[0]
        while True:
            slow=nums[slow] #flyoids cycle detection algorithm
            fast=nums[nums[fast]]
            if fast== slow: # detects the cycle(duplicates creates the cycle)
                break
        fast=nums[0] 
        while slow!=fast:
            slow=nums[slow]
            fast=nums[fast]
        return fast
        
