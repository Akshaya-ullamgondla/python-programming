class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        if not nums:
            return 0
        k=1 # k is pointer always initalized at the nums[1] index
        for i in range(1,len(nums)):
            if nums[i]!=nums[i-1]:# comparing the presnt element and perivous element
                nums[k]=nums[i] 
                k+=1 
        return k # the place where the k pointer is that is the answer
        
        
